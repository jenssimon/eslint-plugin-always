{
  "name": "eslint-plugin-always",
  "version": "0.0.0",
  "description": "ESLint plugin that always reports with configurable message",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin"
  ],
  "homepage": "https://github.com/jenssimon/eslint-plugin-always#readme",
  "bugs": {
    "url": "https://github.com/jenssimon/eslint-plugin-always/issues"
  },
  "license": "MIT",
  "author": "Jens Simon <https://github.com/jenssimon>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jenssimon/eslint-plugin-always.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test",
    "check": "vp check",
    "release": "semantic-release",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "bumpp": "^12.0.0",
    "semantic-release": "^25.0.8",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.15.1",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">=14.17.0"
  }
}
